generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Director {
  id        String  @id @default(uuid())
  name      String
  birthYear Int?
  movies    Movie[]
}

model Movie {
  id          String   @id @default(uuid())
  title       String
  releaseYear Int
  directorId  String
  director    Director @relation(fields: [directorId], references: [id])
}
